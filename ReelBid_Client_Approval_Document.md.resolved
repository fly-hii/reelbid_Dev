flowchart TD
    A["Seller Dashboard"] --> B["Click 'Create Auction'"]
    B --> C["Fill Auction Form"]
    C --> D["Title, Description, Category"]
    D --> E["Upload Images (base64)"]
    E --> F["Set Starting Price"]
    F --> G["Set Security Deposit %<br/>(1% - 50%)"]
    G --> H["Set Start Date & End Date"]
    H --> I["Profanity check on fields"]
